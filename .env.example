# Azure Speech Service
AZURE_SPEECH_REGION=eastus2
AZURE_SPEECH_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# Foundry Agent (Responses API)
FOUNDRY_ENDPOINT=https://<project>.services.ai.azure.com
FOUNDRY_AGENT_NAME=my-agent

# Optional: Override speech output format (default: audio-16khz-32kbitrate-mono-mp3)
# TTS_OUTPUT_FORMAT=audio-16khz-32kbitrate-mono-mp3

# Optional: Override STT language (default: en-US)
# STT_LANGUAGE=en-US

# Optional: Comma-separated STT locales for multi-language support (default: en-US)
# STT_LOCALES=en-US,es-ES

# Optional: TTS voice name (default: en-US-AvaMultilingualNeural)
# TTS_VOICE=en-US-AvaMultilingualNeural
